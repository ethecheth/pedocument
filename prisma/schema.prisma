generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WikiPage {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  content   String
  updatedAt DateTime @updatedAt
  versions  WikiVersion[]
  images    Image[]
}

model WikiVersion {
  id        String   @id @default(uuid())
  pageId    String
  content   String
  createdAt DateTime @default(now())
  page      WikiPage @relation(fields: [pageId], references: [id])
}

model Image {
  id        String   @id @default(uuid())
  url       String
  filename  String
  pageId    String?
  page      WikiPage? @relation(fields: [pageId], references: [id])
}
